* Packaging the app in a container

  I write a Dagger function that gets a Python container with Flask
  installed, injects my app, and verifies it loads:

  #+NAME: flask_app_loads
  #+begin_src fixtureyaml :eval no-export
userfunction: flask-routes
project: examples/flask_application
func: alpine-python-user-venv
args:
  pip-packages: [flask]
chain:
  - with-file:
      path: /app/app.py
      source: "${ROOT}/examples/flask_application/app.py"
  - with-exec: [python3, -c, "from app import app; print(sorted(r.rule for r in app.url_map.iter_rules() if r.rule != '/static/<path:filename>'))"]
  - stdout
  #+end_src

