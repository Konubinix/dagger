* Pinning dependencies with pip-tools

  I don't want surprise upgrades breaking the pipeline at 3am. I use
  =pip-compile= to lock all transitive dependencies from my
  =requirements.in=:

  #+begin_src bash :tangle requirements.in :shebang "" :eval no-export :comments no :padline no
requests
  #+end_src

  #+NAME: pip_compile
  #+begin_src fixtureyaml :eval no-export
userfunction: pip-lock
project: examples/python_environment
func: pip-tools
chain:
  - with-file:
      path: /home/sam/requirements.in
      source: "${ROOT}/examples/python_environment/requirements.in"
  - with-exec: [sh, -c, "pip-compile --quiet requirements.in && head -5 requirements.txt"]
  - stdout
  #+end_src

